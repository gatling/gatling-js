{
  "name": "gatling-ts-demo",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "target/bundle",
  "dependencies": {
    "@gatling.io/core": "0.0.0",
    "@gatling.io/http": "0.0.0",
    "ajv": "6.12.5",
    "atob": "2.1.2",
    "base-64": "1.0.0",
    "btoa": "1.2.1",
    "crypto-js": "4.2.0",
    "csv-parse": "1.2.4",
    "lodash": "4.17.21",
    "moment": "2.30.1",
    "tv4": "1.3.0"
  },
  "devDependencies": {
    "@gatling.io/cli": "0.0.0",
    "@types/base-64": "1.0.2",
    "@types/crypto-js": "4.2.2",
    "prettier": "3.4.2",
    "rimraf": "6.0.1",
    "typescript": "5.7.3"
  },
  "scripts": {
    "clean": "rimraf target",
    "format": "prettier --write '**/*.ts'",
    "setup": "gatling install",
    "check": "tsc --noEmit",
    "build": "tsc --noEmit && gatling build --typescript",
    "start": "gatling run",
    "recorder": "gatling recorder --typescript"
  }
}
