{
  "name": "gatling-ts-demo",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "target/bundle",
  "dependencies": {
    "@gatling.io/core": "3.15.3",
    "@gatling.io/grpc": "3.15.3",
    "@gatling.io/http": "3.15.3",
    "@gatling.io/mqtt": "3.15.3",
    "uuid": "14.0.0"
  },
  "devDependencies": {
    "@gatling.io/cli": "3.15.3",
    "prettier": "3.8.3",
    "rimraf": "6.1.2",
    "typescript": "6.0.2"
  },
  "scripts": {
    "clean": "rimraf target",
    "format": "prettier --write '**/*.ts'",
    "setup": "gatling install",
    "check": "tsc --noEmit",
    "build": "tsc --noEmit && gatling build --typescript",
    "start": "gatling run",
    "recorder": "gatling recorder --typescript"
  }
}
